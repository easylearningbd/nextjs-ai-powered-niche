generator client {
  provider = "prisma-client-js" 
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// All Enums Type 
enum Role {
  USER
  ADMIN
}
 
enum PlanType {
  FREE
  PRO
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  APPROVED 
  REJECTED
}


// User Table Model 
model User {
  id                String @id @default(cuid())
  name              String?
  email             String @unique
  emailVerified     DateTime?
  password          String
  image             String?
  role              Role @default(USER)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
 
  // Relations 
  accounts        Account[]
  sessions        Session[]
  subscription    Subscription?
  reports         Report[]
  usage           UsageLog[]
  paymentRequests PaymentRequest[]

  @@map("users")

}

// NextAuth Account Model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}


// NextAuth Session Model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth Verification Token Model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}


// Subscription Model
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  planType  PlanType @default(FREE)
  startDate DateTime @default(now())
  endDate   DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// Usage Log Model (tracks monthly usage)
model UsageLog {
  id              String   @id @default(cuid())
  userId          String
  month           Int // 1-12
  year            Int
  validationCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("usage_logs")
}


// Report Model
model Report { 
  id        String       @id @default(cuid())
  userId    String
  niche     String       @db.VarChar(255)
  keyword   String       @db.VarChar(255)
  status    ReportStatus @default(PENDING)
  isPublic  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
 
  // JSON fields for storing analysis data
  trendsData        Json? // Stores Google Trends data
  aiInsights        Json? // Stores AI-generated insights
  competitionData   Json? // Stores competition analysis
  monetizationIdeas Json? // Stores monetization suggestions
  gtmStrategy       Json? // Stores go-to-market strategy

  // Summary fields
  overallScore     Float?  @default(0) // 0-100 score
  viabilityRating  String? // HIGH, MEDIUM, LOW
  summaryText      String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([niche])
  @@index([createdAt])
  @@map("reports")
}

// Payment Request Model (for bank transfer payments)
model PaymentRequest {
  id              String        @id @default(cuid())
  userId          String
  transactionId   String        @db.VarChar(255)
  invoicePath     String        @db.VarChar(500)
  status          PaymentStatus @default(PENDING)
  rejectedReason  String?       @db.Text
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_requests")
}

// Trending Niches Model (for email alerts)
model TrendingNiche {
  id              String   @id @default(cuid())
  niche           String   @unique @db.VarChar(255)
  trendScore      Float    @default(0) // Based on search volume growth
  searchVolume    Int      @default(0)
  growthRate      Float    @default(0)
  lastChecked     DateTime @default(now())
  notificationSent Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([trendScore])
  @@index([lastChecked])
  @@map("trending_niches")
}








